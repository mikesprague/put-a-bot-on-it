{
  "name": "put-a-bot-on-it",
  "version": "0.1.0",
  "private": "true",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "type": "module",
  "exports": "./src/index.js",
  "scripts": {
    "dev": "NODE_ENV=development bun --watch --inspect=0.0.0.0:9229 run ./src/index.js ",
    "do-co:up": "docker-compose -f ./docker-compose.dev.yml up",
    "do-co:down": "docker-compose -f ./docker-compose.dev.yml down --rmi 'all'",
    "format": "bun x oxfmt src",
    "format:check": "bun x oxfmt --check src",
    "lint": "bun x oxlint src",
    "slash-deploy": "NODE_ENV=production bun run ./src/deploy-slash-commands.js",
    "start": "NODE_ENV=production bun run ./src/index.js",
    "prestart": "bun run slash-deploy",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@nastyox/rando.js": "2.0.6",
    "common-tags": "1.8.2",
    "dayjs": "1.11.20",
    "discord.js": "14.26.4",
    "he": "1.2.0",
    "node-localstorage": "3.0.5",
    "openai": "6.36.0",
    "randomcolor": "0.6.2",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "bun": "1.3.13",
    "cz-git": "1.13.0",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "engines": {
    "bun": ">= 1.3.x"
  },
  "volta": {
    "node": "26.0.0",
    "npm": "11.13.0"
  },
  "packageManager": "bun@1.3.13"
}
